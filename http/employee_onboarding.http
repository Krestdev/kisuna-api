#                 "document_type": "ID_CARD",
#                 "path": "s3://krest-hr/docs/john_doe_id.pdf",
#                 "expired_date": "2028-01-01T00:00:00Z"
#             }
#         }
#     ]
# }
# in case of error in document upload
# {
#     "statusCode": 409,
#     "message": [
#         {
#             "success": false,
#             "error": "Document with name john_doe_id.pdf already exists"
#         }
#     ]
# }
# in case request body is invalid
# {
#     "statusCode": 400,
#     "message": [
#         {
#             "property": "file_name",
#             "value": "",
#             "constraints": {
#                 "isNotEmpty": "File name must not be empty"
#             }
#         },
#         {
#             "property": "document_type",
#             "value": "",
#             "constraints": {
#                 "isNotEmpty": "Document type must not be empty"
#             }
#         }
#     ]
# }

### 4. Create an Active Contract for the Employee
# @name createContract
POST {{baseUrl}}/employees/{{employeeId}}/contracts
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "startDate": "2024-01-01T00:00:00Z",
  "endDate": "2025-01-01T00:00:00Z",
  "contract_type": "FULL_TIME",
  "baseSalary": 500000,
  "currency": "XAF",
  "companyId": "{{companyId}}"
}

# response of contract creation
# {
