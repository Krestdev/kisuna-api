// This is your Prisma schema file
// Based on your HR Management System ERD

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  uuid        String   @id @default(uuid())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(100)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  departments Department[]
  contracts   Contract[]
  employees   Employee[]
}

model Department {
  uuid        String   @id @default(uuid())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [uuid])

  employeeUuid String?  @unique
  employee     Employee? @relation("DepartmentManager", fields: [employeeUuid], references: [uuid])

  positions Position[]
}

model Position {
  uuid        String   @id @default(uuid())
  title       String   @db.VarChar(100)
  description String?  @db.VarChar(100)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  level       Int?

  departmentId String
  department   Department @relation(fields: [departmentId], references: [uuid])

  employeeUuid String?  @unique
  employee     Employee? @relation("PositionEmployee", fields: [employeeUuid], references: [uuid])

  permissions PositionPermission[]
}

model Permission {
  uuid        String   @id @default(uuid())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(100)
  createdAt   DateTime @default(now())

  positions PositionPermission[]
}

model PositionPermission {
  positionUuid String
  position     Position @relation(fields: [positionUuid], references: [uuid])

  permissionUuid String
  permission     Permission @relation(fields: [permissionUuid], references: [uuid])

  @@id([positionUuid, permissionUuid])
}

enum ContractType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  FREELANCE
  TEMPORARY
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

model Contract {
  uuid              String         @id @default(uuid())
  startDate         DateTime
  endDate           DateTime
  contract_type     ContractType
  status            ContractStatus @default(ACTIVE)
  baseSalary        Int
  currency          String         @default("XAF")
  terminationReason String?
  expiryAlertSent   Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])

  companyId String
  company   Company @relation(fields: [companyId], references: [uuid])

  payrolls Payroll[]
}

model Employee {
  uuid                  String    @id @default(uuid())
  firstName             String    @db.VarChar(100)
  lastName              String    @db.VarChar(100)
  address               String?   @db.VarChar(255)
  phoneNumber           Int?
  gender                Gender
  birthday              DateTime?
  matrimonial_status    Int?
  number_of_children    Int?
  CNPSNumber            BigInt?
  emergencyContactName  String?   @db.VarChar(100)
  EmergencyContactPhone BigInt?
  hireDate              DateTime?
  status                String?   @db.VarChar(10)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [uuid])

  attendances        Attendance[]
  files              File[]
  payslips           Payslip[]
  contracts          Contract[]
  schedules          EmployeeSchedule[]
  managedDepartments Department[]       @relation("DepartmentManager")
  positions          Position[]         @relation("PositionEmployee")
  user               User?
}

enum Gender {
  MALE
  FEMALE
}

enum SystemRole {
  SUPER_ADMIN
  ADMIN
  USER
}

model Attendance {
  uuid       String   @id @default(uuid())
  checkin    String?  @db.VarChar(10)
  checkOut   String?  @db.VarChar(10)
  workedHour Int?
  overtimes  Int?
  status     String?  @db.VarChar(10)
  createdAt  DateTime @default(now())
  updateAt   DateTime @updatedAt

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])

  payrollUuid String?
  payroll     Payroll? @relation(fields: [payrollUuid], references: [uuid])
}

enum DocumentType {
  ID_CARD
  RESUME
  CONTRACT
  OTHER
}

model File {
  uuid          String        @id @default(uuid())
  file_name     String        @db.VarChar(100)
  document_type DocumentType? @default(OTHER)
  path          String?       @db.VarChar(255)
  expired_date  DateTime?
  createAt      DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])

  payslips Payslip[]
}

model EmployeeSchedule {
  uuid      String   @id @default(uuid())
  schedule  Int?
  startDate DateTime
  endDate   DateTime

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])
}

model Payroll {
  uuid      String   @id @default(uuid())
  startDate DateTime
  endDate   DateTime
  status    Int?
  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt

  contractId String
  contract   Contract @relation(fields: [contractId], references: [uuid])

  payslipId String?
  payslip   Payslip? @relation(fields: [payslipId], references: [uuid])

  attendances Attendance[]
}

model Payslip {
  uuid        String    @id @default(uuid())
  totalAmount Int?
  issueDate   DateTime?

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])

  filesId String?
  file    File? @relation(fields: [filesId], references: [uuid])

  payrolls Payroll[]
}

model User {
  uuid         String     @id @default(uuid())
  email        String     @unique @db.VarChar(100)
  passwordHash String     @db.VarChar(255)
  refreshToken String?    @db.VarChar(255)
  role         SystemRole @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  employeeId   String?   @unique
  employee     Employee? @relation(fields: [employeeId], references: [uuid])
}
