// This is your Prisma schema file
// Based on your HR Management System ERD

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  uuid        Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(100)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  departments Department[]
  contracts   Contract[]
  employees   Employee[]
}

model Department {
  uuid        Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  companyId Int
  company   Company @relation(fields: [companyId], references: [uuid])

  employeeUuid Int?
  employee     Employee? @relation("DepartmentManager", fields: [employeeUuid], references: [uuid])

  positions Position[]
}

model Position {
  uuid        Int      @id @default(autoincrement())
  title       String   @db.VarChar(100)
  description String?  @db.VarChar(100)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  level       Int?

  departmentId Int
  department   Department @relation(fields: [departmentId], references: [uuid])

  employeeUuid Int?
  employee     Employee? @relation("PositionEmployee", fields: [employeeUuid], references: [uuid])

  permissions PositionPermission[]
}

model Permission {
  uuid        Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(100)
  createdAt   DateTime @default(now())

  positions PositionPermission[]
}

model PositionPermission {
  positionUuid Int
  position     Position @relation(fields: [positionUuid], references: [uuid])

  permissionUuid Int
  permission     Permission @relation(fields: [permissionUuid], references: [uuid])

  @@id([positionUuid, permissionUuid])
}

model Contract {
  uuid          Int      @id @default(autoincrement())
  endDate       DateTime
  contract_type Int
  startDate     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyId Int
  company   Company @relation(fields: [companyId], references: [uuid])

  payrolls Payroll[]
}

model Employee {
  uuid                  Int       @id @default(autoincrement())
  firstName             String    @db.VarChar(100)
  lastName              String    @db.VarChar(100)
  address               String?   @db.VarChar(255)
  phoneNumber           Int?
  gender                Gender
  birthday              DateTime?
  matrimonial_status    Int?
  number_of_children    Int?
  CNPSNumber            Int?
  emergencyContactName  String?   @db.VarChar(100)
  EmergencyContactPhone Int?
  hireDate              DateTime?
  status                String?   @db.VarChar(10)
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  companyId Int?
  company   Company? @relation(fields: [companyId], references: [uuid])

  attendances        Attendance[]
  files              File[]
  payslips           Payslip[]
  schedules          EmployeeSchedule[]
  managedDepartments Department[]       @relation("DepartmentManager")
  positions          Position[]         @relation("PositionEmployee")
  user               User?
}

enum Gender {
  MALE
  FEMALE
}

enum SystemRole {
  SUPER_ADMIN
  ADMIN
  USER
}

model Attendance {
  uuid       Int      @id @default(autoincrement())
  checkin    String?  @db.VarChar(10)
  checkOut   String?  @db.VarChar(10)
  workedHour Int?
  overtimes  Int?
  status     String?  @db.VarChar(10)
  createdAt  DateTime @default(now())
  updateAt   DateTime @updatedAt

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [uuid])

  payrollUuid Int?
  payroll     Payroll? @relation(fields: [payrollUuid], references: [uuid])
}

model File {
  uuid          Int      @id @default(autoincrement())
  file_name     String   @db.VarChar(100)
  document_type String?  @db.VarChar(10)
  path          String?  @db.VarChar(255)
  createAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [uuid])

  payslips Payslip[]
}

model EmployeeSchedule {
  uuid      Int      @id @default(autoincrement())
  schedule  Int?
  startDate DateTime
  endDate   DateTime

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [uuid])
}

model Payroll {
  uuid      Int      @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime
  status    Int?
  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt

  contractId Int
  contract   Contract @relation(fields: [contractId], references: [uuid])

  payslipId Int?
  payslip   Payslip? @relation(fields: [payslipId], references: [uuid])

  attendances Attendance[]
}

model Payslip {
  uuid        Int       @id @default(autoincrement())
  totalAmount Int?
  issueDate   DateTime?

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [uuid])

  filesId Int?
  file    File? @relation(fields: [filesId], references: [uuid])

  payrolls Payroll[]
}

model User {
  uuid         Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(100)
  passwordHash String     @db.VarChar(255)
  refreshToken String?    @db.VarChar(255)
  role         SystemRole @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  employeeId   Int?     @unique
  employee     Employee? @relation(fields: [employeeId], references: [uuid])
}
