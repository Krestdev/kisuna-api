// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  EMPLOYEE
  HR
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  name      String
  firstName String
  lastName  String
  roles     Role[]     @default([EMPLOYEE])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
}

model Employee {
  uuid                             String    @id @default(uuid())
  address                          String?
  phoneNumber                      String?
  birthday                         DateTime?
  gender                           String?   @db.VarChar(50)
  maritalStatus                    String?   @db.VarChar(50)
  nationality                      String?   @db.VarChar(50)
  NumberOfChildren                 Int?      @db.Integer
  CNPSNumber                       String?   @db.VarChar(50)
  identityDocument                 String?   @db.VarChar(50)
  identityDocumentDelivaryDate     DateTime?
  identityDocumentExpiryDate       DateTime?
  identityDocumentDeliveryLocation String?
  identityDocumentPath             String?

  contractStartDate DateTime?
  contractEndDate   DateTime?
  contractPath      String?

  // Company Info
  hireDate       DateTime?
  isActive       Boolean   @default(true)
  status         String?   @db.VarChar(50)
  employmentType String?   @db.VarChar(50)

  // Salaries & Bonuses
  baseSalary  Decimal? @db.Decimal(12, 2)
  bonusAmount Decimal? @db.Decimal(12, 2)

  // Emergency Contact
  emergencyContactName  String?
  emergencyContactPhone String?

  departmentId String?
  positionId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     Int
  user       User        @relation(fields: [userId], references: [id])
  department Department? @relation(fields: [departmentId], references: [uuid])
  position   Position?   @relation(fields: [positionId], references: [uuid])
}

model Department {
  uuid      String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
}

model Position {
  uuid        String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees Employee[]
}
