// This is your Prisma schema file
// Based on your HR Management System ERD

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EarningCategory {
  PRIME
  INDEMNITE
  AVANTAGE_NATURE
}

enum DeclarationType {
  MONTHLY
  START_OF_YEAR
  END_OF_YEAR
}

enum DeclarationStatus {
  DRAFT
  READY
  SUBMITTED
  ACCEPTED
  REJECTED
}

model Company {
  uuid        String   @id @default(uuid())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(100)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  departments  Department[]
  contracts    Contract[]
  employees    Employee[]
  positions    Position[]
  earningItems EarningItem[]
  declarations Declaration[]
}

model Department {
  uuid        String   @id @default(uuid())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [uuid])

  employeeUuid String?   @unique
  employee     Employee? @relation("DepartmentManager", fields: [employeeUuid], references: [uuid])

  positions Position[]
  employees Employee[] @relation("EmployeeDepartment")
}

model Position {
  uuid        String   @id @default(uuid())
  title       String   @db.VarChar(100)
  description String?  @db.VarChar(100)
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  level       Int?

  companyId String
  company   Company @relation(fields: [companyId], references: [uuid])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [uuid])

  permissions PositionPermission[]
}

model Permission {
  uuid        String   @id @default(uuid())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(100)
  createdAt   DateTime @default(now())

  positions PositionPermission[]
}

model PositionPermission {
  positionUuid String
  position     Position @relation(fields: [positionUuid], references: [uuid])

  permissionUuid String
  permission     Permission @relation(fields: [permissionUuid], references: [uuid])

  @@id([positionUuid, permissionUuid])
}

enum ContractType {
  CDI
  CDD
  Stage
  Prestation
  Essai
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

model Contract {
  uuid              String         @id @default(uuid())
  startDate         DateTime
  endDate           DateTime
  contract_type     ContractType
  status            ContractStatus @default(ACTIVE)
  baseSalary        Int
  currency          String         @default("XAF")
  terminationReason String?
  expiryAlertSent   Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])

  companyId String
  company   Company @relation(fields: [companyId], references: [uuid])

  payrolls         Payroll[]
  declarationLines DeclarationLine[]
}

model Employee {
  uuid                  String    @id @default(uuid())
  firstName             String    @db.VarChar(100)
  lastName              String    @db.VarChar(100)
  address               String?   @db.VarChar(255)
  phoneNumber           Int?
  gender                Gender
  birthday              DateTime?
  nationality           String?   @db.VarChar(100)
  countryOfResidence    String?   @db.VarChar(100)
  matrimonial_status    Int?
  number_of_children    Int?
  CNPSNumber            BigInt?
  emergencyContactName  String?   @db.VarChar(100)
  EmergencyContactPhone BigInt?

  // ID Document Information
  idDocumentType       String?   @db.VarChar(50)
  idDocumentNumber     String?   @db.VarChar(100)
  idDocumentIssueDate  DateTime?
  idDocumentExpiryDate DateTime?
  idDocumentIssuePlace String?   @db.VarChar(100)
  idDocumentFileUrl    String?   @db.VarChar(500)

  // Professional Information
  hireDate            DateTime?
  endDate             DateTime?
  position            String?   @db.VarChar(100)
  category            String?   @db.VarChar(100)
  grade               String?   @db.VarChar(100)
  paymentMode         String?   @db.VarChar(50)
  workLocation        String?   @db.VarChar(50)
  workLocationDetails String?   @db.VarChar(255)

  status    String?  @db.VarChar(10)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [uuid])

  departmentId String?
  department   Department? @relation("EmployeeDepartment", fields: [departmentId], references: [uuid])

  supervisorId String?
  supervisor   Employee?  @relation("EmployeeSupervisor", fields: [supervisorId], references: [uuid])
  subordinates Employee[] @relation("EmployeeSupervisor")

  attendances        Attendance[]
  files              File[]
  payslips           Payslip[]
  payrolls           Payroll[]
  contracts          Contract[]
  leaves             Leave[]
  leaveBalances      LeaveBalance[]
  schedules          EmployeeSchedule[]
  managedDepartments Department[]       @relation("DepartmentManager")
  declarationLines   DeclarationLine[]
  user               User?
}

enum Gender {
  MALE
  FEMALE
}

enum SystemRole {
  SUPER_ADMIN // System-wide admin (all companies)
  COMPANY_ADMIN // Company admin (manages one company)
  ADMIN // HR role
  EMPLOYEE // Regular employee
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  FIELD
}

model Attendance {
  uuid         String           @id @default(uuid())
  checkIn      DateTime
  checkOut     DateTime?
  latitude     Float
  longitude    Float
  workedHour   Float?
  overtimes    Float?
  status       AttendanceStatus @default(PRESENT)
  location     String?          @db.VarChar(255)
  mission      String?          @db.VarChar(255)
  observations String?          @db.VarChar(500)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])

  payrollUuid String?
  payroll     Payroll? @relation(fields: [payrollUuid], references: [uuid])
}

enum DocumentType {
  ID_CARD
  RESUME
  CONTRACT
  OTHER
}

model File {
  uuid          String        @id @default(uuid())
  file_name     String        @db.VarChar(100)
  document_type DocumentType? @default(OTHER)
  path          String?       @db.VarChar(255)
  expired_date  DateTime?
  createAt      DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])
}

enum ScheduleStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

model EmployeeSchedule {
  uuid       String         @id @default(uuid())
  startDate  DateTime
  endDate    DateTime
  shiftStart String         @db.VarChar(5) // e.g. "08:00"
  shiftEnd   String         @db.VarChar(5) // e.g. "17:00"
  workDays   String         @db.VarChar(50) // e.g. "MON,TUE,WED,THU,FRI"
  status     ScheduleStatus @default(ACTIVE)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])
}

enum PayrollStatus {
  DRAFT
  PENDING
  APPROVED
  PAID
  CANCELLED
}

model Payroll {
  uuid      String        @id @default(uuid())
  startDate DateTime
  endDate   DateTime
  status    PayrollStatus @default(DRAFT)

  // Salary breakdown
  baseSalary  Float
  overtimePay Float @default(0)
  bonus       Float @default(0)
  deductions  Float @default(0)
  netSalary   Float

  // Work summary
  workedDays    Int
  absentDays    Int   @default(0)
  overtimeHours Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])

  contractId String
  contract   Contract @relation(fields: [contractId], references: [uuid])

  attendances Attendance[]
  payslip     Payslip?
}

model Payslip {
  uuid        String   @id @default(uuid())
  totalAmount Float
  issueDate   DateTime @default(now())
  filePath    String?

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])

  payrollId String  @unique
  payroll   Payroll @relation(fields: [payrollId], references: [uuid])
}

model User {
  uuid         String     @id @default(uuid())
  email        String     @unique @db.VarChar(100)
  passwordHash String     @db.VarChar(255)
  refreshToken String?    @db.VarChar(255)
  role         SystemRole @default(EMPLOYEE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  employeeId String?   @unique
  employee   Employee? @relation(fields: [employeeId], references: [uuid])
}

model Leave {
  uuid            Int         @id @default(autoincrement())
  type            LeaveType
  startDate       DateTime
  endDate         DateTime
  reason          String?     @db.VarChar(255)
  status          LeaveStatus @default(PENDING_MANAGER)
  approvedBy      String?
  rejectReason    String?     @db.VarChar(255)
  justificatifUrl String?     @db.VarChar(500)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])
}

enum LeaveType {
  ANNUAL // paid vacation
  SICK // sick leave
  MATERNITY
  PATERNITY
  UNPAID
  OTHER
}

enum LeaveStatus {
  PENDING_MANAGER
  PENDING_HR
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveBalance {
  uuid          Int @id @default(autoincrement())
  year          Int
  totalDays     Int @default(21)
  usedDays      Int @default(0)
  remainingDays Int @default(21)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])

  @@unique([employeeId, year])
}

model EarningItem {
  uuid      String          @id @default(uuid())
  name      String          @db.VarChar(100)
  category  EarningCategory
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [uuid])

  earnings DeclarationEarning[]

  @@unique([companyId, name])
}

model Declaration {
  uuid        String            @id @default(uuid())
  type        DeclarationType   @default(MONTHLY)
  status      DeclarationStatus @default(DRAFT)
  periodStart DateTime
  periodEnd   DateTime
  submittedAt DateTime?
  submittedBy String?           @db.VarChar(100)
  notes       String?           @db.VarChar(500)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [uuid])

  lines DeclarationLine[]

  @@unique([companyId, periodStart, periodEnd, type])
}

model DeclarationLine {
  uuid                String   @id @default(uuid())
  baseSalary          Float
  baseSalaryTaxable   Boolean  @default(true)
  baseSalaryCotisable Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  declarationId String
  declaration   Declaration @relation(fields: [declarationId], references: [uuid])

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [uuid])

  contractId String
  contract   Contract @relation(fields: [contractId], references: [uuid])

  earnings DeclarationEarning[]

  @@unique([declarationId, employeeId, contractId])
}

model DeclarationEarning {
  uuid      String   @id @default(uuid())
  amount    Float
  taxable   Boolean  @default(false)
  cotisable Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  declarationLineId String
  declarationLine   DeclarationLine @relation(fields: [declarationLineId], references: [uuid])

  earningItemId String
  earningItem   EarningItem @relation(fields: [earningItemId], references: [uuid])

  @@unique([declarationLineId, earningItemId])
}
